package-as: Weather
enable-nolib-creation: no

license-output: LICENSE

externals:
  Libs/LibStub: https://repos.wowace.com/wow/libstub/trunk
  Libs/LibForecast: https://github.com/Meorawr/LibForecast

ignore:
  - Libs/*/*.rockspec
  - Libs/*/*.toc
  - Libs/*/changelog.*
  - Libs/*/CHANGELOG.*
  - Libs/*/docs
  - Libs/*/examples
  - Libs/*/README.*
  - Libs/*/tests
  - Libs/*/.pkgmeta
  - CHANGELOG.md
  - README.md

move-folders:
  Weather/Weather_Collector: Weather_Collector
  Weather/Weather: Weather


manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown